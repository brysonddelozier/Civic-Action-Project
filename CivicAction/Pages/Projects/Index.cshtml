@page
@model CivicAction.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
    var isAdmin = HttpContext.Session.GetString("IsAdmin") == "True";
}

<h1>Projects</h1>
<p><a asp-page="Create">Add New Project</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Organization</th>
            <th>Hours</th>
            <th>Start</th>
            <th>End</th>
            @if (isAdmin)
            {
                <th>Student</th>
                <th>Approved</th>
            }
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model.Projects)
        {
            <tr>
                <td>@project.Title</td>
                <td>@project.Organization</td>
                <td>@project.Hours</td>
                <td>@project.Start</td>
                <td>@project.End</td>
                @if (isAdmin)
                {
                    <td>@project.Student?.FirstMidName @project.Student?.LastName</td>
                    <td>@Html.DisplayFor(modelItem => project.IsApproved)
                    </td>
                }
                <td>
                    <a asp-page="./Details" asp-route-id="@project.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>