@page
@model CivicAction.Pages.RegisterModel
@{ ViewData["Title"] = "Register"; }

<h2>Register</h2>

@if (Model.Error is not null)
{
    <p class="text-danger">@Model.Error</p>
}

<form method="post">
    <div class="form-group">
        <label>First Name</label>
        <input asp-for="FirstMidName" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Email</label>
        <input asp-for="Email" type="email" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Grade</label>
        <select asp-for="Grade" asp-items="Html.GetEnumSelectList<CivicAction.Models.Grade>()"
                class="form-control"></select>
    </div>
    <div class="form-group mt-2">
        <label>School</label>
        <input asp-for="School" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Password</label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Confirm Password</label>
        <input asp-for="Confirm" type="password" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary mt-3">Register</button>
</form>

<p class="mt-3">Already have an account? <a asp-page="/Login">Login</a></p>